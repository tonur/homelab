#!/usr/sbin/nft -f
flush ruleset

table inet filter {
  chain input {
    type filter hook input priority 0;
    policy drop;
    ct state {established, related} accept
    iif lo accept
    # SSH - always allow (fallback if Tailscale is down)
    tcp dport 22 accept
    # HTTP/HTTPS for HAProxy
    tcp dport { {{ edge_gateway_ingress_ports | join(', ') }} } accept
    # Game server ports
    udp dport {{ edge_gateway_game_port_range }} accept
    tcp dport {{ edge_gateway_game_port_range }} accept
  }
  chain forward {
    type filter hook forward priority 0;
    policy drop;
    ct state {established, related} accept
    # Game traffic: DNAT to k3s node via Tailscale
    iif "eth0" oif "{{ edge_gateway_tailscale_interface }}" udp dport {{ edge_gateway_game_port_range }} accept
    iif "eth0" oif "{{ edge_gateway_tailscale_interface }}" tcp dport {{ edge_gateway_game_port_range }} accept
  }
  chain output {
    type filter hook output priority 0;
    policy accept;
  }
}

table ip nat {
  chain prerouting {
    type nat hook prerouting priority -100;
    # Game ports DNAT direct to k3s node
    udp dport {{ edge_gateway_game_port_range }} dnat to {{ edge_gateway_backend_ip }}
    tcp dport {{ edge_gateway_game_port_range }} dnat to {{ edge_gateway_backend_ip }}
  }
  chain postrouting {
    type nat hook postrouting priority 100;
    # MASQUERADE game traffic through Tailscale
    oif "{{ edge_gateway_tailscale_interface }}" masquerade
  }
}